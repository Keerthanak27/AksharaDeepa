<?xml version="1.0" encoding="utf-8"?>
<androidx.core.widget.NestedScrollView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="#F7FAFC">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:paddingBottom="32dp">

        <TextView
            android:id="@+id/quizTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="00:30"
            android:textColor="#4A5568"
            android:textSize="26sp"
            android:textStyle="bold"
            android:layout_marginTop="24dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/questionCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            app:cardCornerRadius="24dp"
            app:cardElevation="6dp"
            app:cardBackgroundColor="@android:color/white"
            app:layout_constraintTop_toBottomOf="@id/quizTimer"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="24dp">

                <TextView
                    android:id="@+id/questionNumber"
                    android:text="Question 1 of 5"
                    android:textColor="#A0AEC0"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="16dp"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"/>

                <TextView
                    android:id="@+id/questionText"
                    android:text="Loading question..."
                    android:textColor="#2D3748"
                    android:textSize="28sp"
                    android:lineSpacingExtra="4dp"
                    android:fontFamily="sans-serif-medium"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="24dp"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/optionA"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="72dp"
                    android:text="Option A"
                    android:textColor="#2D3748"
                    app:strokeColor="#E2E8F0"
                    android:textSize="24sp"
                    android:textAlignment="textStart"
                    android:layout_marginBottom="12dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/optionB"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="72dp"
                    android:text="Option B"
                    android:textColor="#2D3748"
                    app:strokeColor="#E2E8F0"
                    android:textSize="24sp"
                    android:textAlignment="textStart"
                    android:layout_marginBottom="12dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/optionC"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="72dp"
                    android:text="Option C"
                    android:textColor="#2D3748"
                    app:strokeColor="#E2E8F0"
                    android:textSize="24sp"
                    android:textAlignment="textStart"
                    android:layout_marginBottom="12dp"
                    app:cornerRadius="16dp" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/optionD"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="72dp"
                    android:text="Option D"
                    android:textColor="#2D3748"
                    app:strokeColor="#E2E8F0"
                    android:textSize="24sp"
                    android:textAlignment="textStart"
                    android:layout_marginBottom="12dp"
                    app:cornerRadius="16dp" />

            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/explanationCard"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:cardBackgroundColor="#F0FFF4"
            app:cardCornerRadius="16dp"
            app:cardElevation="2dp"
            app:strokeColor="#68D391"
            app:strokeWidth="1dp"
            app:layout_constraintTop_toBottomOf="@id/questionCard"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Explanation"
                    android:textColor="#276749"
                    android:textStyle="bold"
                    android:textSize="20sp"
                    android:layout_marginBottom="4dp"/>

                <TextView
                    android:id="@+id/explanationText"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Explanation goes here..."
                    android:textColor="#2D3748"
                    android:textSize="20sp"/>
            </LinearLayout>
        </com.google.android.material.card.MaterialCardView>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnNextQuestion"
            style="@style/Widget.Material3.Button"
            android:layout_width="match_parent"
            android:layout_height="72dp"
            android:layout_marginHorizontal="16dp"
            android:layout_marginTop="24dp"
            android:text="Next Question"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@android:color/white"
            android:visibility="gone"
            app:backgroundTint="@color/quiz_green"
            app:cornerRadius="36dp"
            app:layout_constraintTop_toBottomOf="@id/explanationCard"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintVertical_bias="1.0" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.core.widget.NestedScrollView>
