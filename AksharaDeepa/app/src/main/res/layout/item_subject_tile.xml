<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="8dp"
    android:layout_marginVertical="6dp"
    app:cardCornerRadius="20dp"
    app:cardElevation="3dp"
    app:cardBackgroundColor="#FFFFFF"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/iconContainer"
            android:layout_width="56dp"
            android:layout_height="56dp"
            app:cardCornerRadius="16dp"
            app:cardElevation="0dp"
            app:cardBackgroundColor="#F1F5F9"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <ImageView
                android:id="@+id/subjectIcon"
                android:layout_width="32dp"
                android:layout_height="32dp"
                android:layout_gravity="center"
                android:src="@android:drawable/ic_menu_compass"
                app:tint="#475569" />
        </com.google.android.material.card.MaterialCardView>

        <TextView
            android:id="@+id/subjectName"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="16dp"
            android:text="Mathematics"
            android:textColor="#1E293B"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toEndOf="@id/iconContainer"
            app:layout_constraintTop_toTopOf="@id/iconContainer"
            app:layout_constraintBottom_toTopOf="@id/chapterCount" />

        <TextView
            android:id="@+id/chapterCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Start Learning"
            android:textColor="#64748B"
            android:textSize="13sp"
            app:layout_constraintStart_toStartOf="@id/subjectName"
            app:layout_constraintTop_toBottomOf="@id/subjectName"
            app:layout_constraintBottom_toBottomOf="@id/iconContainer" />

        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/subjectProgress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            app:trackCornerRadius="4dp"
            app:trackThickness="8dp"
            app:indicatorColor="#3B82F6"
            app:trackColor="#F1F5F9"
            android:progress="10"
            app:layout_constraintTop_toBottomOf="@id/iconContainer" />

    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>
